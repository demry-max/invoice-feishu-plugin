# ============================================================
# Invoice Generator - 环境变量配置
# ============================================================

# 服务端口
PORT=3000

# 服务基础URL（用于生成 html_url / pdf_url）
BASE_URL=http://localhost:3000

# 飞书模式: mock | real
FEISHU_MODE=mock

# 飞书应用凭证（REAL 模式下需要）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BASE_TOKEN=

# 前端 API 地址（Vite 环境变量）
VITE_API_BASE_URL=http://localhost:3000
VITE_FEISHU_MODE=mock
